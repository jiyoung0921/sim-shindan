# ──────────────────────────────────────────────────────────────────────
# スマホ料金診断 — 環境変数テンプレート
# cp .env.local.example .env.local  してから値を設定してください
# .env.local は .gitignore に含まれています
# ──────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────
# Supabase ダッシュボード → Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サービスロールキー（サーバーサイド専用・フロントエンドに公開しない）
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── 管理画面認証 ────────────────────────────────────────────────────
# 管理API の x-admin-token ヘッダーと照合するシークレット
# openssl rand -hex 32  で生成推奨
ADMIN_SECRET_TOKEN=your-super-secret-admin-token-here

# ─── Slack 通知（任意） ──────────────────────────────────────────────
# Slack Incoming Webhook URL
# Slack ダッシュボード → Apps → Incoming Webhooks で発行
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxx

# ─── サイトの公開URL（sitemap・OGP・JSON-LD に使用） ───────────────
NEXT_PUBLIC_SITE_URL=https://sim-shindan.com

# ─── 管理画面の公開URL（Slack 通知のリンク用） ─────────────────────
# 本番デプロイ時に変更してください
ADMIN_BASE_URL=http://localhost:3000

# ─── スクレイパー設定（Python 側で使用） ───────────────────────────
# Supabase と同じ値を GitHub Secrets にも登録すること
# SUPABASE_URL=          （NEXT_PUBLIC_SUPABASE_URL と同値）
# SUPABASE_SERVICE_KEY=  （上記と同値）
# SLACK_WEBHOOK_URL=     （上記と同値）

# ─── 設定確認チェックリスト ──────────────────────────────────────────
# □ Supabase プロジェクト作成済み
# □ supabase/migrations/001_initial.sql を実行済み
# □ NEXT_PUBLIC_SUPABASE_URL / ANON_KEY を設定済み
# □ SUPABASE_SERVICE_KEY を設定済み
# □ ADMIN_SECRET_TOKEN を設定済み
# □ GitHub Secrets に SUPABASE_URL, SUPABASE_SERVICE_KEY, SLACK_WEBHOOK_URL を登録済み
# □ npm run dev で localhost:3000 が起動することを確認
# □ /admin にアクセスしてダッシュボードが表示されることを確認
